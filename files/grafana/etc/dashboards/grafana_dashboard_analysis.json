                },
                "overrides": [
                    {
                        "matcher": { "id": "byName", "options": "Projection" },
                        "properties": [
                            { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
                            { "id": "custom.fillOpacity", "value": 0 },
                            { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
                        ]
                    },
                    {
                        "matcher": { "id": "byName", "options": "Coût cumulé" },
                        "properties": [
                            { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
                        ]
                    }
                ]
            },
            "gridPos": { "h": 10, "w": 12, "x": 0, "y": 1 },
            "id": 2,
            "options": {
                "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
                "tooltip": { "mode": "multi", "sort": "none" }
            },
            "targets": [
                {
                    "datasource": { "type": "mysql", "uid": "P211906C1C32DB77E" },
                    "editorMode": "code",
                    "format": "time_series",
                    "rawQuery": true,
                    "rawSql": "SELECT\n  day_date AS time,\n  @running := @running + ((HCHP_delta * $prix_hp + HCHC_delta * $prix_hc) / 1000) AS 'Coût cumulé'\nFROM linky_daily_cache,\n  (SELECT @running := $abonnement) AS init\nWHERE day_date >= (\n  CASE\n    WHEN DAY(CURDATE()) >= $jour_releve_compteur\n    THEN STR_TO_DATE(CONCAT(DATE_FORMAT(CURDATE(), '%Y-%m-'), LPAD($jour_releve_compteur, 2, '0')), '%Y-%m-%d')\n    ELSE STR_TO_DATE(CONCAT(DATE_FORMAT(DATE_SUB(CURDATE(), INTERVAL 1 MONTH), '%Y-%m-'), LPAD($jour_releve_compteur, 2, '0')), '%Y-%m-%d')\n  END\n)\nAND day_date <= CURDATE()\nORDER BY day_date",
                    "refId": "A"
                },
                {
                    "datasource": { "type": "mysql", "uid": "P211906C1C32DB77E" },
                    "editorMode": "code",
                    "format": "time_series",
                    "rawQuery": true,
                    "rawSql": "SELECT\n  period_end AS time,\n  (\n    SELECT\n      @total := $abonnement + SUM((HCHP_delta * $prix_hp + HCHC_delta * $prix_hc) / 1000)\n    FROM linky_daily_cache\n    WHERE day_date >= p.period_start AND day_date <= CURDATE()\n  ) / DATEDIFF(CURDATE(), p.period_start) * DATEDIFF(p.period_end, p.period_start) AS 'Projection'\nFROM linky_period_cache p,\n  (SELECT @total := 0) AS init\nWHERE p.period_type = 'month'\n  AND p.period_start <= CURDATE()\n  AND p.period_end > CURDATE()\nLIMIT 1",
                    "refId": "B"
                }
            ],
            "title": "Coût cumulé — Période en cours",
            "type": "timeseries"
        },
        {
