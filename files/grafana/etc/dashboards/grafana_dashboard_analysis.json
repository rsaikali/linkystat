            "description": "Coût cumulé sur la période de facturation en cours (du 24 au 24) avec projection linéaire fin de période.",
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "axisBorderShow": false,
                        "axisCenteredZero": false,
