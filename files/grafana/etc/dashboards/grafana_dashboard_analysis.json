                    "scheme": "Oranges",
                    "steps": 64
                },
                "exemplars": { "color": "rgba(255,0,255,0.7)" },
                "filterValues": { "le": 0 },
                "legend": { "show": true },
                "rowsFrame": { "layout": "auto" },
                "showValue": "never",
                "tooltip": { "mode": "single", "showColorScale": true, "yHistogram": false }
            },
            "targets": [
                {
                    "datasource": { "type": "mysql", "uid": "P211906C1C32DB77E" },
                    "editorMode": "code",
                    "format": "table",
                    "rawQuery": true,
                    "rawSql": "SELECT\n  CONCAT(\n    CASE DAYOFWEEK(time)\n      WHEN 2 THEN '1-Lun'\n      WHEN 3 THEN '2-Mar'\n      WHEN 4 THEN '3-Mer'\n      WHEN 5 THEN '4-Jeu'\n      WHEN 6 THEN '5-Ven'\n      WHEN 7 THEN '6-Sam'\n      WHEN 1 THEN '7-Dim'\n    END\n  ) AS jour,\n  CONCAT(LPAD(HOUR(time), 2, '0'), 'h') AS heure,\n  ROUND(AVG(PAPP) * (\n    (SELECT (MAX(HCHP) - MIN(HCHP) + MAX(HCHC) - MIN(HCHC))\n      / (TIMESTAMPDIFF(SECOND, MIN(time), MAX(time)) / 3600)\n      / AVG(PAPP)\n    FROM linky_realtime)\n  )) AS puissance\nFROM linky_realtime\nWHERE time >= NOW() - INTERVAL 30 DAY\nGROUP BY DAYOFWEEK(time), HOUR(time)\nORDER BY DAYOFWEEK(time), HOUR(time)",
                    "refId": "A"
                }
            ],
            "title": "Heatmap — Consommation par heure et jour de la semaine",
            "transformations": [
                {
                    "id": "prepareTimeSeries",
                    "options": {
                        "format": "many"
                    }
                }
            ],
            "type": "heatmap"
        }
