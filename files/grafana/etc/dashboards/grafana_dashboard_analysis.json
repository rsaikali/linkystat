                {
                    "datasource": { "type": "mysql", "uid": "P211906C1C32DB77E" },
                    "editorMode": "code",
                    "format": "time_series",
                    "rawQuery": true,
                    "rawSql": "SELECT\n  DATE_ADD(day_date, INTERVAL 1 YEAR) AS time,\n  total_kwh AS 'Année précédente'\nFROM linky_daily_cache\nWHERE day_date >= DATE_SUB(\n  CASE\n    WHEN DAY(CURDATE()) >= $jour_releve_compteur\n    THEN STR_TO_DATE(CONCAT(DATE_FORMAT(CURDATE(), '%Y-%m-'), LPAD($jour_releve_compteur, 2, '0')), '%Y-%m-%d')\n    ELSE STR_TO_DATE(CONCAT(DATE_FORMAT(DATE_SUB(CURDATE(), INTERVAL 1 MONTH), '%Y-%m-'), LPAD($jour_releve_compteur, 2, '0')), '%Y-%m-%d')\n  END,\n  INTERVAL 1 YEAR\n)\nAND day_date <= DATE_SUB(CURDATE(), INTERVAL 1 YEAR)\nORDER BY day_date",
                    "refId": "B"
                }
            ],
            "title": "Year-over-Year — Période 24→24",
            "type": "timeseries"
