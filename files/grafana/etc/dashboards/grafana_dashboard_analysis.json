            "description": "Répartition HC/HP et économies réalisées grâce aux heures creuses.\nPlages HC : 23h54-05h24 et 14h24-16h54.",
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "thresholds" },
                    "decimals": 1,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "red", "value": null },
