            "targets": [
                {
                    "datasource": { "type": "mysql", "uid": "P211906C1C32DB77E" },
                    "editorMode": "code",
                    "format": "table",
                    "rawQuery": true,
                    "rawSql": "SELECT\n  standby_w AS 'Puissance veille',\n  ROUND(standby_w * 8760 / 1000 * (($prix_hp + $prix_hc) / 2), 0) AS 'Coût annuel veille',\n  ROUND(standby_w * 8760 / (total_kwh_year * 1000) * 100, 1) AS '% de la conso totale'\nFROM (\n  SELECT\n    ROUND(MIN(PAPP) * (\n      (MAX(HCHP) - MIN(HCHP) + MAX(HCHC) - MIN(HCHC))\n      / (TIMESTAMPDIFF(SECOND, MIN(time), MAX(time)) / 3600)\n      / AVG(PAPP)\n    ) / 5) * 5 AS standby_w\n  FROM linky_realtime\n) AS standby,\n(\n  SELECT total_kwh AS total_kwh_year\n  FROM linky_period_cache\n  WHERE period_type = 'year'\n  ORDER BY period_start DESC\n  LIMIT 1\n) AS yearly",
                    "refId": "A"
                }
            ],
            "title": "Consommation en veille",
            "type": "stat"
        },
